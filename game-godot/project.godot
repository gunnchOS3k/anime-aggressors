; Anime Aggressors — Primary Godot 4 Runtime (game-godot)
config_version=5

[application]
config/name="Anime Aggressors"
config/description="Primary local platform fighter runtime — Godot 4"
run/main_scene="res://scenes/boot/BootScene.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]
GameState="*res://scripts/core/GameState.gd"
SceneRouter="*res://scripts/core/SceneRouter.gd"

[display]
