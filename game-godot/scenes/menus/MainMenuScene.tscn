[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/menus/main_menu_scene.gd" id="1"]
[ext_resource type="Theme" path="res://assets/placeholder/aa_theme.tres" id="2"]

[node name="MainMenuScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
