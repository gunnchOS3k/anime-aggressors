[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/menus/ruleset_scene.gd" id="1"]
[ext_resource type="Theme" path="res://assets/placeholder/aa_theme.tres" id="2"]

[node name="RulesetScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme = ExtResource("2")
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.07, 0.12, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 64.0
offset_top = 64.0
offset_right = -64.0
offset_bottom = -80.0
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Rulesets"

[node name="StockLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Stocks: 3"

[node name="StockRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="StockMinus" type="Button" parent="VBox/StockRow"]
layout_mode = 2
text = "Stocks -"

[node name="StockPlus" type="Button" parent="VBox/StockRow"]
layout_mode = 2
text = "Stocks +"

[node name="CpuLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "CPU Level: 2"

[node name="CpuRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="CpuMinus" type="Button" parent="VBox/CpuRow"]
layout_mode = 2
text = "CPU -"

[node name="CpuPlus" type="Button" parent="VBox/CpuRow"]
layout_mode = 2
text = "CPU +"

[node name="Confirm" type="Button" parent="VBox"]
custom_minimum_size = Vector2(320, 72)
layout_mode = 2
text = "Confirm Ruleset"

[node name="FooterHint" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -48.0
horizontal_alignment = 1

[connection signal="pressed" from="VBox/StockRow/StockMinus" to="." method="_on_stock_minus"]
[connection signal="pressed" from="VBox/StockRow/StockPlus" to="." method="_on_stock_plus"]
[connection signal="pressed" from="VBox/CpuRow/CpuMinus" to="." method="_on_cpu_minus"]
[connection signal="pressed" from="VBox/CpuRow/CpuPlus" to="." method="_on_cpu_plus"]
[connection signal="pressed" from="VBox/Confirm" to="." method="_on_confirm_pressed"]
